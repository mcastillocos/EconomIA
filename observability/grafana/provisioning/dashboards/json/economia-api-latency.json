{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Request Rate por Endpoint",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count[5m])) by (http_route)",
          "legendFormat": "{{http_route}}"
        }
      ]
    },
    {
      "title": "Latencia P95 por Endpoint",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_seconds_bucket[5m])) by (le, http_route))",
          "legendFormat": "{{http_route}}"
        }
      ]
    },
    {
      "title": "Error Rate por Endpoint (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count{http_response_status_code=~\"5..\"}[5m])) by (http_route) / sum(rate(http_server_request_duration_seconds_count[5m])) by (http_route) * 100",
          "legendFormat": "{{http_route}}"
        }
      ]
    },
    {
      "title": "Latencia P50 vs P99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P99"
        }
      ]
    },
    {
      "title": "Requests In-Flight",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(http_server_active_requests)"
        }
      ]
    },
    {
      "title": "Response Size (bytes, avg)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 16 },
      "targets": [
        {
          "expr": "avg(http_server_response_body_size_bytes_sum / http_server_response_body_size_bytes_count)"
        }
      ]
    },
    {
      "title": "Cache Hit/Miss Ratio",
      "type": "piechart",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum(increase(economia_cache_hits_total[1h]))",
          "legendFormat": "Hits"
        },
        {
          "expr": "sum(increase(economia_cache_misses_total[1h]))",
          "legendFormat": "Misses"
        }
      ]
    },
    {
      "title": "Fondos Actualizados / min",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(economia_funds_updated_total[5m])) * 60"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["economia", "api", "latency"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "EconomIA - API Latency & Endpoints",
  "uid": "economia-api-latency"
}
